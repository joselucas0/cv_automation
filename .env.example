# --- Configurações do Provedor de LLM (Groq) ---
GROQ_API_KEY=sua_chave_groq_aqui
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# --- Configurações do Provedor de Embeddings (Ollama Local / OpenAI) ---
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_API_KEY=dummy_key_para_ollama_local # Se usar OpenAI, coloque sua API Key aqui

# --- Configurações da API Backend (opcional se rodar fora do Docker) ---
# OPENAI_API_KEY=sua_chave_openai_aqui
